---
import type { CollectionEntry } from 'astro:content';

interface Props {
	data: CollectionEntry<'writings'>;
}

const { data: post } = Astro.props;

const formatDate = (date: Date) => {
	return date.toLocaleDateString('en-US', {
		year: 'numeric',
		month: 'short',
		day: 'numeric'
	});
};
---

<li class="group">
	<article class="relative py-2 flex gap-4 items-baseline">
		<div class="flex-1">
			<h2 class="text-sm font-medium text-fg group-hover:text-link-fg transition-colors mb-2">
				<a href={`/writings/${post.slug}`} class="after:absolute after:inset-0">
					{post.data.title}
				</a>
			</h2>
			<p class="text-xs text-fg-secondary">{post.data.description}</p>
		</div>
		<div class="shrink-0 flex flex-col items-end gap-2">
			<time
				datetime={post.data.publishedAt.toISOString()}
				class="text-2xs text-right font-mono text-muted-fg"
			>
				{formatDate(post.data.publishedAt)}
			</time>
			<div class="text-2xs w-fit font-mono bg-charcoal-200 px-1 text-muted-fg">
				{post.data.type}
			</div>
		</div>
	</article>
</li>
