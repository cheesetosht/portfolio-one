---
import { EXPERIENCE, TOOLS, PHOTOS, LINKS, SIDE_QUESTS } from '../lib/constants';
import Icon from '@iconify/svelte';
import Eyes from '../components/eyes.svelte';
import ExperienceItem from '../components/experience-item.svelte';
import Tooltip from '../components/tooltip.svelte';
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';
import WritingTile from '../components/WritingTile.astro';
import SideQuests from '../components/SideQuests.astro';

const writings = (await getCollection('writings'))
	.filter((writing: CollectionEntry<'writings'>) => !writing.data.draft)
	.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout>
	<header class="border-y border-border border-dashed flex h-16 sm:h-24 mt-24 sm:mt-40">
		<div class="size-16 sm:size-24">
			<img
				src="/illustration.webp"
				alt="illustration"
				class="size-full object-cover mix-blend-multiply"
			/>
		</div>
		<div
			class="flex-1 border-x border-border border-dashed px-4 sm:px-6 flex flex-col justify-center"
		>
			<h1
				class="select-none cursor-default text-lg sm:text-xl font-semibold tracking-wide leading-none mb-1"
			>
				vraj shah
			</h1>
			<p class="cursor-default select-none text-fg-secondary text-xs sm:text-sm">
				engineer. curious about everything.
			</p>
		</div>
		<div class="relative flex justify-center items-center size-16 sm:size-24">
			<Eyes client:load />
			<span
				class="hint-fade text-right w-16 absolute -top-8 right-2 text-2xs text-forest-400 italic sm:hidden"
			>
				tap anywhere</span
			>
		</div>
	</header>
	<main>
		<section class="py-6 px-4 sm:px-6 space-y-2.5">
			<p class="text-fg-secondary">
				currently vibing <a class="group" target="_blank" href="https://ns.com/cheesetosht/invite"
					>@ns<Icon
						client:load
						icon="tabler:arrow-up-right"
						class="size-3 inline-block group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300"
					/></a
				>
			</p>
			<p class="text-fg-secondary">
				i craft products with <b class="shimmer">taste</b> &
				<i class="font-medium">speed</i>. my recent work sits at an intersection of product, design,
				& data in industries like consumer apps, finance, healthcare & ai.
			</p>
			<p class="text-fg-secondary">
				i care deeply about the parts others skip over. most of my work starts where someone else
				stopped thinking.
			</p>
		</section>
		<section class="border-y border-border border-dashed py-4 px-4 sm:px-6">
			<div class="text-xs font-mono font-medium leading-normal flex gap-3 items-center flex-wrap">
				{
					LINKS.map((link) => (
						<a class="group hover:no-underline!" href={link.href} target="_blank">
							{link.label}
							{/* @ts-expect-error - Iconify Svelte types not properly recognized in Astro */}
							<Icon
								client:load
								icon="tabler:arrow-up-right"
								class="size-3 inline-block group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform duration-300"
							/>
						</a>
					))
				}
			</div>
		</section>
		<section class="px-4 sm:px-6 pt-6">
			<h2 class="cursor-default select-none text-sm text-muted-fg tracking-wider mb-1">work</h2>
			{
				EXPERIENCE.map((experience) => (
					<ExperienceItem
						client:visible
						year={experience.year}
						company={experience.company}
						title={experience.title}
						points={experience.points}
						link={experience.link}
						caption={experience?.caption}
					/>
				))
			}
		</section>
		<section class="px-4 sm:px-6 py-6">
			<div id="photos-grid" class="columns-2 sm:columns-3 gap-2 space-y-2">
				{
					PHOTOS.map((photo, index) => (
						<div
							class="photo-item break-inside-avoid relative overflow-hidden"
							style={`--i: ${index}`}
						>
							<Tooltip caption={photo.caption} class={'w-full h-full text-center leading-3'}>
								<img
									src={photo.src}
									alt={photo.alt}
									class={
										'w-full object-cover grayscale group-hover:grayscale-0 group-focus:grayscale-0 transition-all duration-600 group-hover:scale-105 group-focus:scale-105 ' +
										photo.class
									}
								/>
							</Tooltip>
						</div>
					))
				}
			</div>
		</section>
		<section id="writings" class="border-y border-border border-dashed px-4 sm:px-6 py-6">
			<h2 class="cursor-default select-none text-sm text-muted-fg tracking-wider mb-2">writings</h2>
			<ul class="space-y-4">
				{writings.map((writing: CollectionEntry<'writings'>) => <WritingTile data={writing} />)}
			</ul>
		</section>
		<section class="px-4 sm:px-6 py-6">
			<h2 class="cursor-default select-none text-sm text-muted-fg tracking-wider mb-3">
				side-quests & projects
			</h2>
			<SideQuests quests={SIDE_QUESTS} />
		</section>
		<section class="border-y border-border border-dashed px-4 sm:px-6 py-3 overflow-hidden">
			<div class="marquee font-mono text-2xs uppercase text-muted-fg space-x-1.5 sm:space-x-3">
				<div class="marquee-content space-x-3">
					{
						TOOLS.map((tool) => (
							<>
								<span>{tool.name}</span>
								<span>&#10033;</span>
							</>
						))
					}
				</div>
				<div class="marquee-content space-x-3" aria-hidden="true">
					{
						TOOLS.map((tool) => (
							<>
								<span>{tool.name}</span>
								<span>&#10033;</span>
							</>
						))
					}
				</div>
			</div>
		</section>
		<!-- <section class="px-4 sm:px-6 py-6">
			<h2 class="cursor-default select-none text-sm text-muted-fg tracking-wider mb-2">
				more about me
			</h2>
			<p class="text-fg-secondary">
			</p>
			</section> -->
	</main>

	<footer class="py-6 sm:py-8 px-4 sm:px-6">
		<div class="flex items-center gap-2 justify-between">
			<small class="text-2xs text-muted-fg font-light"
				>(last updated: 2026-02-06)
				<br />
				<a href="https://0708eb8c.portfolio-one-6z5.pages.dev/" target="_blank"
					>visit previous version</a
				>
			</small>
			<div class="text-right">
				<h6 class="text-xs text-muted-fg">thanks for visiting!</h6>
				<small class="text-2xs text-muted-fg font-light"
					>built with astro&nbsp;
					{/* @ts-expect-error - Iconify Svelte types not properly recognized in Astro */}
					<Icon client:load icon="simple-icons:astro" class="size-3 inline-block align-bottom" />
				</small>
			</div>
		</div>
	</footer>
</BaseLayout>

<style>
	.hint-fade {
		animation: hintFade 5s ease-in-out forwards;
	}

	@keyframes hintFade {
		0% {
			opacity: 0;
		}
		15% {
			opacity: 1;
		}
		30% {
			opacity: 0.6;
		}
		45% {
			opacity: 1;
		}
		60% {
			opacity: 0.6;
		}
		75% {
			opacity: 1;
		}
		90% {
			opacity: 0.6;
		}
		100% {
			opacity: 0;
		}
	}

	.marquee {
		cursor: pointer;
		display: flex;
		width: max-content;
		animation: marquee 20s linear infinite;
	}

	.marquee:hover {
		animation-play-state: paused;
	}

	.marquee-content {
		display: flex;
		flex-shrink: 0;
	}

	@keyframes marquee {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	.photo-item {
		opacity: 0;
	}

	@media (prefers-reduced-motion: no-preference) {
		@keyframes photoIn {
			0% {
				opacity: 0;
				transform: translateY(8px) scale(0.98);
			}
			100% {
				opacity: 1;
				transform: none;
			}
		}

		#photos-grid.in-view .photo-item {
			animation: photoIn 500ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
			animation-delay: calc(var(--i) * 80ms);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		#photos-grid.in-view .photo-item {
			opacity: 1;
		}
	}
</style>

<script>
	const grid = document.getElementById('photos-grid');
	if (grid) {
		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						grid.classList.add('in-view');
						observer.disconnect();
						break;
					}
				}
			},
			{ threshold: 0.1, rootMargin: '0px 0px -10% 0px' }
		);
		observer.observe(grid);
	}
</script>
