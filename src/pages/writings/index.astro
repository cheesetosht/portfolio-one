---
import { getCollection, type CollectionEntry } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import WritingTile from '../../components/WritingTile.astro';
import Icon from '@iconify/svelte';

const writings = (await getCollection('writings'))
	.filter((writing: CollectionEntry<'writings'>) => !writing.data.draft)
	.sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
---

<BaseLayout title="Writings - Vraj Shah" description="Thoughts on engineering, products, and more">
	<div class="py-6 px-4 sm:px-6">
		<header class="mb-8">
			<a
				href="/"
				class="text-xs text-muted-fg hover:text-fg-secondary inline-flex items-center gap-1 mb-4"
			>
				{/* @ts-expect-error - Iconify Svelte types not properly recognized in Astro */}
				<Icon client:load icon="tabler:arrow-left" class="size-3" />
				home
			</a>
			<h1 class="text-2xl sm:text-3xl font-semibold tracking-wide leading-tight mb-2">writings</h1>
			<p class="text-fg-secondary">thoughts on engineering, products, and more</p>
		</header>

		{
			writings.length === 0 ? (
				<p class="text-muted-fg text-sm">no posts yet. check back soon!</p>
			) : (
				<ul class="space-y-4">
					{writings.map((post: CollectionEntry<'writings'>) => (
						<WritingTile data={post} />
					))}
				</ul>
			)
		}
	</div>
</BaseLayout>
