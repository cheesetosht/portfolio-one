---
import BaseLayout from '../layouts/BaseLayout.astro';
import resume from '../content/resume.json';

function formatDate(dateStr: string) {
	if (!dateStr) return 'Present';
	const d = new Date(dateStr);
	return d.toLocaleDateString('en-US', { month: 'short', year: 'numeric' });
}

function trimUrl(url: string) {
	return url.replace(/^https?:\/\//, '');
}

function isoDatetime(dateStr: string) {
	return dateStr ? dateStr.slice(0, 7) : '';
}

function profileUrl(p: { network: string; username: string; url?: string }) {
	if (p.url) return p.url;
	const net = p.network.toLowerCase();
	return `https://${net}.com/${net === 'linkedin' ? 'in/' : ''}${p.username}`;
}

const {
	basics,
	work,
	volunteer,
	education,
	awards,
	certificates,
	publications,
	skills,
	languages,
	interests,
	references,
	projects
} = resume as any;
const loc = basics.location ?? {};
const locationStr = [loc.city, loc.region, loc.countryCode].filter(Boolean).join(', ');
---

<BaseLayout title="Vraj Shah - Resume" description={basics.summary}>
	<div class="resume-container px-4 py-8">
		<!-- Header -->
		<header class="resume-header pb-5 border-b border-dashed border-border">
			<div class="resume-header-identity">
				<h1 class="font-heading text-2xl font-bold text-fg">{basics.name}</h1>
				{basics.label && <p class="text-fg-secondary">{basics.label}</p>}
				{locationStr && <p class="text-xs text-muted-fg">{locationStr}</p>}
			</div>
			<address class="resume-header-links not-italic text-xs flex flex-col gap-0.5 text-right">
				{
					basics.phone && (
						<a
							href={`tel:${basics.phone}`}
							aria-label="Phone"
							class="text-link-fg hover:text-link-fg-hover"
						>
							{basics.phone}
						</a>
					)
				}
				{
					basics.email && (
						<a
							href={`mailto:${basics.email}`}
							aria-label="Email"
							class="text-link-fg hover:text-link-fg-hover"
						>
							{basics.email}
						</a>
					)
				}
				{
					basics.url && (
						<a href={basics.url} aria-label="Website" class="text-link-fg hover:text-link-fg-hover">
							{trimUrl(basics.url)}
						</a>
					)
				}
				{
					basics.profiles?.map((p: any) => (
						<a
							href={profileUrl(p)}
							aria-label={p.network}
							class="text-link-fg hover:text-link-fg-hover"
						>
							{trimUrl(profileUrl(p))}
						</a>
					))
				}
			</address>
			{
				basics.summary && (
					<p class="resume-header-summary mt-3 text-xs text-fg-secondary leading-relaxed">
						{basics.summary}
					</p>
				)
			}
		</header>

		<!-- Work Experience -->
		{
			work?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Experience</h2>
					<div class="space-y-5">
						{work.map((job: any) => (
							<article class="work-item">
								<h3 class="font-heading font-semibold text-fg text-sm">{job.position}</h3>
								<p class="text-xs text-fg-secondary">
									{job.url ? (
										<a href={job.url} class="text-link-fg hover:text-link-fg-hover">
											{job.name}
										</a>
									) : (
										job.name
									)}
								</p>
								{job.location && <p class="text-xs text-muted-fg">{job.location}</p>}
								<p class="text-xs text-muted-fg">
									<time datetime={isoDatetime(job.startDate)}>{formatDate(job.startDate)}</time>
									{' – '}
									<time datetime={isoDatetime(job.endDate)}>{formatDate(job.endDate)}</time>
								</p>
								{job.description && <p class="text-xs text-fg-secondary">{job.description}</p>}
								{job.summary && <p class="text-xs text-fg-secondary">{job.summary}</p>}
								{job.highlights?.length > 0 && (
									<ul class="mt-1.5 space-y-1">
										{job.highlights.map((h: string) => (
											<li class="highlight-item">{h}</li>
										))}
									</ul>
								)}
							</article>
						))}
					</div>
				</section>
			)
		}

		<!-- Projects -->
		{
			projects?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Projects</h2>
					<div class="space-y-4">
						{projects.map((proj: any) => (
							<article class="work-item">
								<h3 class="font-heading font-semibold text-sm text-fg">
									{proj.url ? (
										<a href={proj.url} class="text-link-fg hover:text-link-fg-hover">
											{proj.name}
										</a>
									) : (
										proj.name
									)}
								</h3>
								{proj.entity && <p class="text-xs text-fg-secondary">{proj.entity}</p>}
								{proj.type && <p class="text-xs text-muted-fg">Type: {proj.type}</p>}
								{(proj.startDate || proj.endDate) && (
									<p class="text-xs text-muted-fg">
										<time datetime={isoDatetime(proj.startDate)}>{formatDate(proj.startDate)}</time>
										{' – '}
										<time datetime={isoDatetime(proj.endDate)}>{formatDate(proj.endDate)}</time>
									</p>
								)}
								{proj.description && (
									<p class="text-xs text-fg-secondary mt-0.5">{proj.description}</p>
								)}
								{proj.roles?.length > 0 && (
									<p class="text-xs text-muted-fg">Roles: {proj.roles.join(', ')}</p>
								)}
								{proj.keywords?.length > 0 && (
									<p class="text-xs text-muted-fg">Technologies: {proj.keywords.join(', ')}</p>
								)}
								{proj.highlights?.length > 0 && (
									<ul class="mt-1.5 space-y-1">
										{proj.highlights.map((h: string) => (
											<li class="highlight-item">{h}</li>
										))}
									</ul>
								)}
							</article>
						))}
					</div>
				</section>
			)
		}

		<!-- Skills -->
		{
			skills?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Skills</h2>
					<dl class="space-y-1.5">
						{skills.map((skill: any) => (
							<div class="flex gap-2">
								<dt class="text-2xs font-semibold text-muted-fg uppercase tracking-wide w-28 shrink-0 pt-0.5">
									{skill.name}
									{skill.level ? ` (${skill.level})` : ''}
								</dt>
								<dd class="text-xs text-fg-secondary">{skill.keywords.join(', ')}</dd>
							</div>
						))}
					</dl>
				</section>
			)
		}

		<!-- Education -->
		{
			education?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Education</h2>
					<div class="space-y-3">
						{education.map((edu: any) => (
							<article>
								<h3 class="font-heading font-semibold text-sm text-fg">
									{edu.studyType} - {edu.area}
								</h3>
								<p class="text-xs text-fg-secondary">
									{edu.url ? (
										<a href={edu.url} class="text-link-fg hover:text-link-fg-hover">
											{edu.institution}
										</a>
									) : (
										edu.institution
									)}
								</p>
								<p class="text-xs text-muted-fg">
									<time datetime={isoDatetime(edu.startDate)}>{formatDate(edu.startDate)}</time>
									{' – '}
									<time datetime={isoDatetime(edu.endDate)}>{formatDate(edu.endDate)}</time>
								</p>
								{edu.score && <p class="text-xs text-muted-fg">Score: {edu.score}</p>}
								{edu.courses?.length > 0 && (
									<p class="text-xs text-muted-fg">Courses: {edu.courses.join(', ')}</p>
								)}
							</article>
						))}
					</div>
				</section>
			)
		}

		<!-- Volunteer -->
		{
			volunteer?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Volunteer</h2>
					<div class="space-y-4">
						{volunteer.map((v: any) => (
							<article class="work-item">
								<h3 class="font-heading font-semibold text-sm text-fg">{v.position}</h3>
								<p class="text-xs text-fg-secondary">
									{v.url ? (
										<a href={v.url} class="text-link-fg hover:text-link-fg-hover">
											{v.organization}
										</a>
									) : (
										v.organization
									)}
								</p>
								<p class="text-xs text-muted-fg">
									<time datetime={isoDatetime(v.startDate)}>{formatDate(v.startDate)}</time>
									{' – '}
									<time datetime={isoDatetime(v.endDate)}>{formatDate(v.endDate)}</time>
								</p>
								{v.summary && <p class="text-xs text-fg-secondary">{v.summary}</p>}
								{v.highlights?.length > 0 && (
									<ul class="mt-1.5 space-y-1">
										{v.highlights.map((h: string) => (
											<li class="highlight-item">{h}</li>
										))}
									</ul>
								)}
							</article>
						))}
					</div>
				</section>
			)
		}

		<!-- Awards -->
		{
			awards?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Awards</h2>
					<div class="space-y-3">
						{awards.map((award: any) => (
							<article>
								<h3 class="font-heading font-semibold text-sm text-fg">{award.title}</h3>
								{award.awarder && <p class="text-xs text-fg-secondary">{award.awarder}</p>}
								{award.date && (
									<p class="text-xs text-muted-fg">
										<time datetime={isoDatetime(award.date)}>{formatDate(award.date)}</time>
									</p>
								)}
								{award.summary && <p class="text-xs text-fg-secondary">{award.summary}</p>}
							</article>
						))}
					</div>
				</section>
			)
		}

		<!-- Certificates -->
		{
			certificates?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Certificates</h2>
					<div class="space-y-3">
						{certificates.map((cert: any) => (
							<article>
								<h3 class="font-heading font-semibold text-sm text-fg">
									{cert.url ? (
										<a href={cert.url} class="text-link-fg hover:text-link-fg-hover">
											{cert.name}
										</a>
									) : (
										cert.name
									)}
								</h3>
								{cert.issuer && <p class="text-xs text-fg-secondary">{cert.issuer}</p>}
								{cert.date && (
									<p class="text-xs text-muted-fg">
										<time datetime={cert.date}>{formatDate(cert.date)}</time>
									</p>
								)}
							</article>
						))}
					</div>
				</section>
			)
		}

		<!-- Publications -->
		{
			publications?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Publications</h2>
					<div class="space-y-3">
						{publications.map((pub: any) => (
							<article>
								<h3 class="font-heading font-semibold text-sm text-fg">
									{pub.url ? (
										<a href={pub.url} class="text-link-fg hover:text-link-fg-hover">
											{pub.name}
										</a>
									) : (
										pub.name
									)}
								</h3>
								{pub.publisher && <p class="text-xs text-fg-secondary">{pub.publisher}</p>}
								{pub.releaseDate && (
									<p class="text-xs text-muted-fg">
										<time datetime={isoDatetime(pub.releaseDate)}>
											{formatDate(pub.releaseDate)}
										</time>
									</p>
								)}
								{pub.summary && <p class="text-xs text-fg-secondary">{pub.summary}</p>}
							</article>
						))}
					</div>
				</section>
			)
		}

		<!-- Languages -->
		{
			languages?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Languages</h2>
					<dl class="space-y-1">
						{languages.map((lang: any) => (
							<div class="flex gap-2">
								<dt class="text-xs font-semibold text-fg w-28 shrink-0">{lang.language}</dt>
								{lang.fluency && <dd class="text-xs text-fg-secondary">{lang.fluency}</dd>}
							</div>
						))}
					</dl>
				</section>
			)
		}

		<!-- Interests -->
		{
			interests?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">Interests</h2>
					<dl class="space-y-1">
						{interests.map((interest: any) => (
							<div class="flex gap-2">
								<dt class="text-xs font-semibold text-fg w-28 shrink-0">{interest.name}</dt>
								{interest.keywords?.length > 0 && (
									<dd class="text-xs text-fg-secondary">{interest.keywords.join(', ')}</dd>
								)}
							</div>
						))}
					</dl>
				</section>
			)
		}

		<!-- References -->
		{
			references?.length > 0 && (
				<section class="resume-section">
					<h2 class="section-label">References</h2>
					<div class="space-y-3">
						{references.map((ref: any) => (
							<article>
								<h3 class="font-heading font-semibold text-sm text-fg">{ref.name}</h3>
								{ref.reference && (
									<blockquote class="text-xs text-fg-secondary mt-1 pl-3 border-l-2 border-border">
										{ref.reference}
									</blockquote>
								)}
							</article>
						))}
					</div>
				</section>
			)
		}
	</div>

	<button onclick="window.print()" class="print-btn" aria-label="Export as PDF">
		Export PDF
	</button>
</BaseLayout>

<style>
	.resume-header {
		display: grid;
		grid-template-columns: 1fr auto;
		grid-template-areas: 'identity links' 'summary summary';
		align-items: start;
		gap: 0 1rem;
	}
	.resume-header-identity {
		grid-area: identity;
	}
	.resume-header-links {
		grid-area: links;
	}
	.resume-header-summary {
		grid-area: summary;
	}

	.resume-section {
		padding-top: 1.25rem;
		padding-bottom: 1.25rem;
		border-bottom: 1px dashed var(--color-border);
	}

	.section-label {
		font-family: var(--font-heading);
		font-size: 0.625rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-muted-fg);
		margin-bottom: 0.75rem;
	}

	.highlight-item {
		font-size: 0.75rem;
		color: var(--color-fg-secondary);
		padding-left: 0.25rem;
		list-style-type: '– ';
	}

	.print-btn {
		position: fixed;
		bottom: 1.5rem;
		right: 1.5rem;
		padding: 0.5rem 1rem;
		font-family: var(--font-sans);
		font-size: 0.75rem;
		font-weight: 500;
		background-color: var(--color-forest-950);
		color: var(--color-charcoal-50);
		border: none;
		border-radius: 0.375rem;
		cursor: pointer;
		box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
		transition: background-color 0.15s ease;
	}
	.print-btn:hover {
		background-color: var(--color-forest-800);
	}

	@media print {
		.print-btn {
			display: none;
		}
		:global(.container) {
			max-width: none !important;
			padding-left: 0 !important;
			padding-right: 0 !important;
		}
		:global(.border-x) {
			border: none !important;
		}

		body,
		h1,
		h2,
		h3,
		h4,
		h5,
		h6,
		.section-label,
		.highlight-item {
			font-family: Arial, Helvetica, sans-serif !important;
		}

		a {
			color: inherit;
			text-decoration: none;
		}

		.resume-container {
			padding: 0;
		}

		.work-item {
			break-inside: avoid;
		}
	}
</style>
